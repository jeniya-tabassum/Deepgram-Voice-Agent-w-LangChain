# Deepgram API key — powers the Voice Agent (STT + TTS + conversation orchestration).
# Get one at https://console.deepgram.com/
DEEPGRAM_API_KEY=your_deepgram_key_here

# OpenAI API key — powers the LangChain "brain" (the agent that answers support questions).
# Get one at https://platform.openai.com/
OPENAI_API_KEY=your_openai_key_here

# Optional override
LANGCHAIN_LLM_MODEL=gpt-4o-mini    # the LLM that powers the LangChain support agent
# (The Deepgram think LLM — Gemini — is configured in app/deepgram_agent.py.)
